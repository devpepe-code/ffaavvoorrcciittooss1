generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  phoneVerified Boolean   @default(false)
  passwordHash  String?
  firstName     String
  lastName      String
  profileImage  String?
  role          String    @default("CLIENTE")
  language      String    @default("es")
  country       String
  city          String
  address       String?
  coordinates   String?
  subscriptionTier String @default("FREE")
  subscriptionEnd  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  taskerProfile     TaskerProfile?
  bookingsAsClient  Booking[]     @relation("ClientBookings")
  bookingsAsTasker  Booking[]     @relation("TaskerBookings")
  reviews           Review[]
  notifications     Notification[]
  transactions      Transaction[]
  favorites         Favorite[]
  accounts          Account[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TaskerProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  verificationStatus  String    @default("PENDING")
  idDocumentUrl       String?
  backgroundCheckUrl  String?
  backgroundCheckDate DateTime?
  bio                 String?
  services            String
  hourlyRates         String
  coverageRadius      Int       @default(10)
  yearsOfExperience   Int?
  portfolioImages     String?
  isAvailableNow      Boolean   @default(false)
  weeklySchedule      String?
  blockedDates        String?
  averageRating       Float     @default(0)
  totalReviews        Int       @default(0)
  completedJobs       Int       @default(0)
  acceptanceRate      Float     @default(100)
  cancellationRate    Float     @default(0)
  responseTime        Int?
  availableBalance    Float     @default(0)
  pendingBalance      Float     @default(0)
  totalEarnings      Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  taskerId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id               String   @id @default(cuid())
  clientId         String
  taskerId         String
  serviceCategory  String
  title            String
  description      String
  attachments      String?
  address          String
  coordinates      String?
  scheduledDate    DateTime
  estimatedHours   Float
  actualStartTime  DateTime?
  actualEndTime    DateTime?
  hourlyRate       Float
  estimatedTotal   Float
  finalTotal       Float?
  platformFee       Float
  trustSupportFee   Float
  status           String   @default("PENDING")
  paymentIntentId  String?
  paymentStatus    String   @default("PENDING")
  paymentMethod    String?
  escrowReleased   Boolean  @default(false)
  cancellationReason String?
  cancelledBy      String?
  disputeOpen      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client  User    @relation("ClientBookings", fields: [clientId], references: [id])
  tasker  User    @relation("TaskerBookings", fields: [taskerId], references: [id])
  review  Review?
}

model Review {
  id               String   @id @default(cuid())
  bookingId        String   @unique
  reviewerId       String
  reviewedId       String
  reviewerType     String
  overallRating    Int
  qualityRating    Int?
  punctualityRating Int?
  professionalismRating Int?
  cleanlinessRating Int?
  comment          String?
  badges           String?
  tipAmount        Float?
  response         String?
  respondedAt      DateTime?
  createdAt        DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id])
  reviewer User     @relation(fields: [reviewerId], references: [id])
}

model Transaction {
  id              String   @id @default(cuid())
  bookingId       String?
  userId          String
  type            String
  amount          Float
  currency        String   @default("MXN")
  status          String
  paymentMethod   String
  paymentIntentId String?
  description     String
  createdAt       DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  actionUrl String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
