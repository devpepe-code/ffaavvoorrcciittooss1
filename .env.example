# Database (Neon PostgreSQL)
favoritosdatabase_POSTGRES_PRISMA_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google Maps (Mexico)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Defaults
NEXT_PUBLIC_DEFAULT_LAT=19.4326
NEXT_PUBLIC_DEFAULT_LNG=-99.1332
NEXT_PUBLIC_DEFAULT_CITY=Ciudad de México
